#!/bin/sh

# Prints the current volume or Ύγσ if muted.

case $BLOCK_BUTTON in
	1) setsid -f "$TERMINAL" -e pulsemixer ;;
	2) pamixer -t ;;
	4) pamixer --allow-boost -i 1 ;;
	5) pamixer --allow-boost -d 1 ;;
	3) notify-send "ΏθΥλ Volume module" "\- Shows volume ΎΑρ, Ύγσ if muted.
- Middle click to mute.
- Scroll to change." ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

[ $(pamixer --get-mute) = true ] && echo Ύγσ && exit

vol="$(pamixer --get-volume)"

if [ "$vol" -gt "50" ]; then
	icon="ΎΑρ "
elif [ "$vol" -gt "30" ]; then
	icon="ΎΑπ "
elif [ "$vol" -gt "0" ]; then
	icon="ΎΑο "
else
        echo Ύγσ && exit
fi

echo "$icon$vol%"
