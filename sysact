#!/bin/sh
# A dmenu wrapper script for system functions.

case "$(printf "п‹µ Logout\nп†ё Renew\nп‹№ Reboot\nпЂ‘ Kill\nпЉ‹ Sleep" | dmenu -i -b)" in
	'п‹µ Logout') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'п†ё Renew') kill -HUP "$(pgrep -u "$USER" "\bdwm$")" ;;
	'пЉ‹ Sleep') slock & systemctl suspend ;;
	'п‹№ Reboot') reboot ;;
	'пЂ‘ Kill') shutdown -h now ;;
	*) exit 1 ;;
esac
