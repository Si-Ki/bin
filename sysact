#!/bin/sh
# A dmenu wrapper script for system functions.
case "$(readlink -f /sbin/init)" in
	*systemd*) ctl='systemctl' ;;
	*) ctl='loginctl' ;;
esac

case "$(printf "пЂЈ lock\nп‹µ log out\nп†ё renew dwm\nрџђ» hibernate\nрџ’¤ sleep\nпЃ№ reboot\nп‡¦ shutdown" | dmenu -i -b)" in
	'пЂЈ lock') gpg-connect-agent --no-autostart reloadagent /bye && xset dpms force off; slock ;;
	'п‹µ log out') kill -TERM "$(pgrep -u "$USER" "\bdwm$")" ;;
	'п†ё renew dwm') kill -HUP "$(pgrep -u "$USER" "\bdwm$")" ;;
	'рџђ» hibernate') slock $ctl hibernate ;;
	'рџ’¤ sleep') slock & $ctl suspend ;;
	'пЃ№ reboot') $ctl reboot ;;
	'п‡¦ shutdown') $ctl poweroff ;;
	*) exit 1 ;;
esac
